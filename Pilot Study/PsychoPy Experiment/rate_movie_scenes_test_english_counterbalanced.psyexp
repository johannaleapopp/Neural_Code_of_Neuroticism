        <Param val="" valType="code" updates="constant" name="stopVal"/>
        <Param val="True" valType="bool" updates="None" name="syncScreenRefresh"/>
        <Param val="This was the test scene.&amp;#10;&amp;#10;If you encountered issues with your audio or video setup, please try to resolve them now and press the Enter key to replay the test scene.&amp;#10;&amp;#10;If your audio and video setup is functioning properly, please press the spacebar to start with the movie scene ratings. " valType="str" updates="constant" name="text"/>
